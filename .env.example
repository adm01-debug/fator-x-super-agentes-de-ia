# ═══════════════════════════════════════════════════════════
# FATOR X — Environment Variables
# ═══════════════════════════════════════════════════════════

# ── Supabase (required) ──────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── HuggingFace (required for HF integrations) ──────────
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── HF Feature Toggles (all default to true) ────────────
ENABLE_ML_INJECTION_CHECK=true
ENABLE_HF_RERANKER=true
ENABLE_HF_EMBEDDINGS=true
ENABLE_AUTO_CLASSIFY=true

# ── HF Self-Hosted TEI (optional, for high volume) ──────
# HF_TEI_ENDPOINT=http://localhost:8080
# HF_TEI_RERANK_ENDPOINT=http://localhost:8081

# ── LLM Providers (at least one required) ────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_AI_API_KEY=AI...
# OPENROUTER_API_KEY=sk-or-...
LOVABLE_API_KEY=

# ── External Databases (for DataHub) ─────────────────────
# BANCODADOSCLIENTES_URL=https://xxx.supabase.co
# BANCODADOSCLIENTES_SERVICE_ROLE_KEY=eyJ...
# FUCHSIA_KITE_URL=https://xxx.supabase.co
# FUCHSIA_KITE_SERVICE_ROLE_KEY=eyJ...
# GESTAO_TIME_PROMO_URL=https://xxx.supabase.co
# GESTAO_TIME_PROMO_SERVICE_ROLE_KEY=eyJ...
# BACKUPGIFTSTORE_URL=https://xxx.supabase.co
# BACKUPGIFTSTORE_SERVICE_ROLE_KEY=eyJ...
